{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-native-book.dev/schemas/vla/task-plan/v1.0.0",
  "title": "TaskPlan",
  "description": "Structured task sequence generated by LLM for robot execution",
  "type": "object",
  "required": ["tasks", "feasibility", "metadata"],
  "properties": {
    "tasks": {
      "type": "array",
      "description": "Ordered list of tasks to execute",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/definitions/Task"
      }
    },
    "feasibility": {
      "$ref": "#/definitions/FeasibilityAssessment"
    },
    "metadata": {
      "$ref": "#/definitions/PlanMetadata"
    }
  },
  "definitions": {
    "Task": {
      "type": "object",
      "required": ["task_id", "task_type", "parameters", "preconditions", "expected_duration"],
      "properties": {
        "task_id": {
          "type": "integer",
          "description": "Unique task identifier within plan",
          "minimum": 1
        },
        "task_type": {
          "type": "string",
          "description": "Type of task to execute",
          "enum": ["navigate", "detect", "manipulate", "inspect"]
        },
        "parameters": {
          "type": "object",
          "description": "Task-specific parameters (structure varies by task_type)",
          "additionalProperties": true
        },
        "preconditions": {
          "type": "array",
          "description": "task_ids that must complete before this task",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "expected_duration": {
          "type": "number",
          "description": "Estimated execution time in seconds",
          "minimum": 0.1,
          "maximum": 3600
        }
      }
    },
    "FeasibilityAssessment": {
      "type": "object",
      "required": ["is_feasible", "confidence"],
      "properties": {
        "is_feasible": {
          "type": "boolean",
          "description": "Whether plan is feasible to execute"
        },
        "confidence": {
          "type": "number",
          "description": "Confidence in feasibility assessment",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "warnings": {
          "type": "array",
          "description": "Potential issues or caveats",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PlanMetadata": {
      "type": "object",
      "required": ["llm_model", "generation_time", "schema_version"],
      "properties": {
        "llm_model": {
          "type": "string",
          "description": "Model used to generate plan",
          "examples": ["gpt-4", "gpt-3.5-turbo", "llama-3.1-70b"]
        },
        "prompt_tokens": {
          "type": "integer",
          "description": "Number of input tokens consumed",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "description": "Number of output tokens generated",
          "minimum": 0
        },
        "generation_time": {
          "type": "number",
          "description": "LLM generation latency in seconds",
          "minimum": 0
        },
        "schema_version": {
          "type": "string",
          "description": "Task plan schema version",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.0.0"]
        }
      }
    }
  }
}
